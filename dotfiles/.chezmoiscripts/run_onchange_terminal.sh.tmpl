#!/bin/bash
# com.apple.Terminal.plist hash: {{ include (joinPath .chezmoi.homeDir "Library/Preferences/com.apple.Terminal.plist") | sha256sum }}

set -euo pipefail

source_plist="$HOME/Library/Preferences/com.apple.Terminal.plist"
tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

/usr/bin/plutil -convert binary1 -o "$tmpdir/com.apple.Terminal.plist" "$source_plist"
/usr/bin/defaults import com.apple.Terminal "$tmpdir/com.apple.Terminal.plist"